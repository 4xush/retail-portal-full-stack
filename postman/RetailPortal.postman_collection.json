{
  "info": {
    "name": "RetailPortal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "apiKey", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman.user@demo.com\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.code === 201);",
                  "const j = pm.response.json();",
                  "pm.test('success', () => j.success === true);",
                  "if (j.data?.accessToken) pm.collectionVariables.set('accessToken', j.data.accessToken);",
                  "if (j.data?.apiKey) pm.collectionVariables.set('apiKey', j.data.apiKey);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@demo.com\",\n  \"password\": \"User@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.code === 200);",
                  "const j = pm.response.json();",
                  "pm.test('success', () => j.success === true);",
                  "if (j.data?.accessToken) pm.collectionVariables.set('accessToken', j.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.code === 200);",
                  "const j = pm.response.json();",
                  "pm.test('success', () => j.success === true);",
                  "if (j.data?.accessToken) pm.collectionVariables.set('adminToken', j.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"REPLACE_ME\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"REPLACE_ME\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Suggest",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/search/suggest?q=bur" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.code === 200);",
                  "pm.test('success', () => pm.response.json().success === true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Full search",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/search?q=burger&page=1&limit=20" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.code === 200);",
                  "const j = pm.response.json();",
                  "pm.test('success', () => j.success === true);",
                  "pm.test('data array', () => Array.isArray(j.data));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.code === 200);",
                  "pm.test('success', () => pm.response.json().success === true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?page=1&limit=8" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List (auth)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/orders?page=1&limit=10"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/dashboard"
          }
        },
        {
          "name": "Discount codes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/discount-codes"
          }
        }
      ]
    }
  ]
}

{
  "info": {
    "name": "RetailPortal",
    "_postman_id": "retail-portal-v2",
    "description": "Full test suite for the RetailPortal API.\n\n**Workflow**\n1. Run `Auth / Login Admin` → adminToken auto-set\n2. Run `Auth / Login User` → accessToken auto-set; apiKey auto-set\n3. Run any folder — tokens are injected automatically.\n\n**API Key auth**: pass `x-api-key: {{apiKey}}` header as an alternative to Bearer.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000" },
    { "key": "accessToken",  "value": "" },
    { "key": "adminToken",   "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "apiKey",       "value": "" },
    { "key": "productId",    "value": "" },
    { "key": "categoryId",   "value": "" },
    { "key": "orderId",      "value": "" },
    { "key": "discountId",   "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman.new@demo.com\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const j = pm.response.json();",
              "pm.test('success flag', () => pm.expect(j.success).to.be.true);",
              "pm.test('accessToken present', () => pm.expect(j.data.accessToken).to.be.a('string'));",
              "pm.test('apiKey present', () => pm.expect(j.data.apiKey).to.be.a('string'));",
              "if (j.data?.accessToken) pm.collectionVariables.set('accessToken', j.data.accessToken);",
              "if (j.data?.apiKey)       pm.collectionVariables.set('apiKey', j.data.apiKey);"
            ]}
          }]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@demo.com\",\n  \"password\": \"User@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('success flag', () => pm.expect(j.success).to.be.true);",
              "pm.test('accessToken present', () => pm.expect(j.data.accessToken).to.be.a('string'));",
              "pm.test('apiKey present', () => pm.expect(j.data.apiKey).to.be.a('string'));",
              "if (j.data?.accessToken)  pm.collectionVariables.set('accessToken', j.data.accessToken);",
              "if (j.data?.refreshToken) pm.collectionVariables.set('refreshToken', j.data.refreshToken);",
              "if (j.data?.apiKey)       pm.collectionVariables.set('apiKey', j.data.apiKey);"
            ]}
          }]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('success flag', () => pm.expect(j.success).to.be.true);",
              "pm.test('role is admin', () => pm.expect(j.data.user.role).to.equal('admin'));",
              "if (j.data?.accessToken)  pm.collectionVariables.set('adminToken', j.data.accessToken);",
              "if (j.data?.refreshToken) pm.collectionVariables.set('refreshToken', j.data.refreshToken);"
            ]}
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('new accessToken', () => pm.expect(j.data.accessToken).to.be.a('string'));",
              "if (j.data?.accessToken) pm.collectionVariables.set('accessToken', j.data.accessToken);"
            ]}
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('success flag', () => pm.expect(pm.response.json().success).to.be.true);"
            ]}
          }]
        },
        {
          "name": "API Key Auth (x-api-key header)",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}" }],
            "url": "{{baseUrl}}/api/orders"
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200 with API key', () => pm.response.to.have.status(200));",
              "pm.test('success flag', () => pm.expect(pm.response.json().success).to.be.true);"
            ]}
          }]
        }
      ]
    },


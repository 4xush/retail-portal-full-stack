        },
        {
          "name": "Discount Codes — List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/discount-codes"
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('array', () => pm.expect(j.data).to.be.an('array'));",
              "pm.test('at least 3 codes', () => pm.expect(j.data.length).to.be.gte(3));",
              "if (j.data[0]?._id) pm.collectionVariables.set('discountId', j.data[0]._id);"
            ]}
          }]
        },
        {
          "name": "Discount Codes — Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/discount-codes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"PMTEST\",\n  \"type\": \"percent\",\n  \"value\": 15,\n  \"minOrder\": 0,\n  \"usageLimit\": 100\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Created or conflict', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));"
            ]}
          }]
        },
        {
          "name": "Discount Codes — Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/discount-codes/{{discountId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"
            ]}
          }]
        },
        {
          "name": "Non-admin access — expect 403",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/dashboard"
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Non-admin gets 403', () => pm.response.to.have.status(403));"
            ]}
          }]
        }
      ]
    }

